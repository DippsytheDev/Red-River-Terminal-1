# Server
PORT=5000
# Leave as "*" to allow all origins, or set to your frontend origin(s), e.g.
# CORS_ORIGIN=https://redriverterminal.com,https://www.redriverterminal.com
CORS_ORIGIN=*

# SMTP (examples)
SMTP_HOST=smtp.yourmailserver.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contact@redriverterminal.com
SMTP_PASS=CHANGE_ME

# Email routing
MAIL_TO=contact@redriverterminal.com
MAIL_FROM_NAME=Red River Terminal
MAIL_FROM_EMAIL=contact@redriverterminal.com

